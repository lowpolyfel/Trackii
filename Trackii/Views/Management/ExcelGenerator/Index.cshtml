@model Trackii.Models.Admin.ExcelGenerator.ExcelGeneratorLandingVm

@{
    ViewData["Title"] = "Generador de Excel";
}

<div class="card">
    <div class="page-header">
        <div>
            <h2>Generador de Excel</h2>
            <p class="subtitle">Selecciona el tipo de exportación. Cada módulo abre su vista dedicada con preview y archivo listo para descargar.</p>
        </div>
    </div>

    <div class="excel-generator-grid">
        <a class="card excel-generator-option" href="/Admin/ExcelGenerator/RoutesBySubfamily">
            <div class="excel-generator-icon icon-routes">
                <i class="fa-solid fa-route"></i>
            </div>
            <div>
                <h3>Rutas por subfamilia</h3>
                <p>Incluye producto, familia y todos los pasos de ruta en formato de tabla limpia para ingeniería y producción.</p>
            </div>
            <div class="excel-generator-meta">
                <span>@Model.RoutesBySubfamilyTotalRows registros</span>
                <span class="btn btn-secondary btn-sm">Abrir módulo</span>
            </div>
        </a>

        <a class="card excel-generator-option" href="/Admin/ExcelGenerator/ActiveOrders">
            <div class="excel-generator-icon icon-orders">
                <i class="fa-solid fa-stopwatch"></i>
            </div>
            <div>
                <h3>Órdenes activas congeladas</h3>
                <p>Tabla de órdenes activas totales ordenadas de la más antigua a la más reciente, con ubicación congelada y días parada.</p>
            </div>
            <div class="excel-generator-meta">
                <span>@Model.ActiveOrdersTotalRows registros</span>
                <span class="btn btn-secondary btn-sm">Abrir módulo</span>
            </div>
        </a>
    </div>
</div>
