@{
    ViewData["Title"] = "Excel | Purga de Work Order";
}

<div class="card work-order-purge-card">
    <div class="page-header">
        <div>
            <h2>Purga de Work Order</h2>
            <p class="subtitle">Carga un Excel y compara la <strong>columna A</strong> contra las órdenes registradas en la base de datos.</p>
        </div>

        <a href="/Admin/ExcelGenerator" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i>
            Regresar
        </a>
    </div>

    <form id="purgeForm" method="post" action="/Admin/ExcelGenerator/WorkOrderPurge/Analyze" enctype="multipart/form-data" class="work-order-purge-form">
        @Html.AntiForgeryToken()

        <div class="purge-upload-row">
            <input type="file" id="excelFile" name="excelFile" class="input" accept=".xlsx" required />
            <input type="text" id="sheetName" name="sheetName" class="input purge-sheet-input" value="Reports" placeholder="Nombre de hoja (ej: Reports)" />
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-bolt"></i>
                Analizar archivo
            </button>
        </div>

        <div class="purge-hint">Por defecto se analiza la hoja <strong>Reports</strong> (normalmente la #3). Se toma la columna A del Excel global y se identifica qué WO activas del sistema ya no están ahí.</div>
    </form>

    <div id="purgeProgress" class="purge-progress hidden" aria-live="polite">
        <div class="purge-progress-header">
            <strong>Procesando archivo...</strong>
            <span id="purgeProgressLabel">0%</span>
        </div>
        <div class="purge-progress-bar-track">
            <div id="purgeProgressBar" class="purge-progress-bar"></div>
        </div>
    </div>

    <div id="purgeError" class="alert error hidden"></div>

    <section id="purgeResults" class="purge-results hidden">
        <div class="kpi-grid purge-kpis">
            <article class="card kpi-card purge-kpi">
                <div class="kpi-title">Hoja analizada</div>
                <div id="kpiSheetUsed" class="kpi-value kpi-text">-</div>
            </article>
            <article class="card kpi-card purge-kpi">
                <div class="kpi-title">Filas leídas (col. A)</div>
                <div id="kpiRowsRead" class="kpi-value">0</div>
            </article>
            <article class="card kpi-card purge-kpi">
                <div class="kpi-title">WO únicas en Excel</div>
                <div id="kpiExcelUnique" class="kpi-value">0</div>
            </article>
            <article class="card kpi-card purge-kpi">
                <div class="kpi-title">WO activas en sistema</div>
                <div id="kpiSystemActive" class="kpi-value">0</div>
            </article>
            <article class="card kpi-card purge-kpi">
                <div class="kpi-title">WO activas presentes en Excel</div>
                <div id="kpiPresentInExcel" class="kpi-value">0</div>
            </article>
            <article class="card kpi-card purge-kpi purge-kpi-alert">
                <div class="kpi-title">WO en sistema y NO en Excel</div>
                <div id="kpiMissingInExcel" class="kpi-value">0</div>
            </article>
        </div>

        <div class="table-wrapper excel-preview-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Work Order candidata para desactivar (no aparece en Excel)</th>
                    </tr>
                </thead>
                <tbody id="purgeMissingBody"></tbody>
            </table>
        </div>

        <div id="purgeActions" class="purge-actions hidden">
            <button type="button" id="purgeDeactivateBtn" class="btn btn-danger">
                <i class="fa-solid fa-trash"></i>
                Purgar masivamente (active=0, status=CANCELLED)
            </button>
            <div id="purgeDeactivateMsg" class="purge-action-message"></div>
        </div>
    </section>
</div>

@section Scripts {
<script>
(() => {
    const form = document.getElementById('purgeForm');
    const progressContainer = document.getElementById('purgeProgress');
    const progressBar = document.getElementById('purgeProgressBar');
    const progressLabel = document.getElementById('purgeProgressLabel');
    const errorBox = document.getElementById('purgeError');
    const results = document.getElementById('purgeResults');
    const missingBody = document.getElementById('purgeMissingBody');
    const purgeActions = document.getElementById('purgeActions');
    const purgeDeactivateBtn = document.getElementById('purgeDeactivateBtn');
    const purgeDeactivateMsg = document.getElementById('purgeDeactivateMsg');
    let latestMissingWos = [];

    const setProgress = (value) => {
        const safeValue = Math.max(0, Math.min(100, value));
        progressBar.style.width = `${safeValue}%`;
        progressLabel.textContent = `${safeValue}%`;
    };

    const showError = (message) => {
        errorBox.classList.remove('hidden');
        errorBox.innerHTML = `<i class="fa-solid fa-circle-xmark"></i> ${message}`;
    };

    const clearError = () => {
        errorBox.classList.add('hidden');
        errorBox.innerHTML = '';
    };

    const setKpiValue = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = Number(value ?? 0).toLocaleString();
    };

        const renderMissingRows = (missingList) => {
            missingBody.innerHTML = '';

        if (!Array.isArray(missingList) || missingList.length === 0) {
            latestMissingWos = [];
            purgeActions.classList.add('hidden');
            missingBody.innerHTML = '<tr><td colspan="2" class="empty">Excelente: todas tus WO activas del sistema sí aparecen en el Excel global.</td></tr>';
            return;
        }

        latestMissingWos = missingList;
        purgeActions.classList.remove('hidden');
        missingBody.innerHTML = missingList
            .map((wo, index) => `<tr><td>${index + 1}</td><td>${wo}</td></tr>`)
            .join('');
    };

    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearError();
        results.classList.add('hidden');
        purgeActions.classList.add('hidden');
        purgeDeactivateMsg.textContent = '';
        progressContainer.classList.remove('hidden');
        setProgress(0);

        const formData = new FormData(form);
        const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;

        let progress = 0;
        const timer = setInterval(() => {
            progress = Math.min(progress + 6, 90);
            setProgress(progress);
        }, 180);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: token ? { 'RequestVerificationToken': token } : {}
            });

            const payload = await response.json();
            if (!response.ok) {
                showError(payload?.error || 'No se pudo procesar el archivo.');
                return;
            }

            setProgress(100);

            const sheetEl = document.getElementById('kpiSheetUsed');
            if (sheetEl) sheetEl.textContent = payload.sheetUsed || '-';

            setKpiValue('kpiRowsRead', payload.totalRowsRead);
            setKpiValue('kpiExcelUnique', payload.uniqueWorkOrdersInExcel);
            setKpiValue('kpiSystemActive', payload.activeWorkOrdersInSystem);
            setKpiValue('kpiPresentInExcel', payload.presentInExcel);
            setKpiValue('kpiMissingInExcel', payload.missingInExcel);
            renderMissingRows(payload.missingFromExcelWorkOrders);

            results.classList.remove('hidden');
        } catch (error) {
            showError('Error inesperado al procesar el archivo. Intenta nuevamente.');
        } finally {
            clearInterval(timer);
            setTimeout(() => progressContainer.classList.add('hidden'), 350);
        }
    });

    purgeDeactivateBtn.addEventListener('click', async () => {
        if (!latestMissingWos.length) {
            purgeDeactivateMsg.textContent = 'No hay órdenes para purgar.';
            return;
        }

        const ok = confirm(`Se desactivarán ${latestMissingWos.length} orden(es) y se pondrán en CANCELLED. ¿Deseas continuar?`);
        if (!ok) return;

        purgeDeactivateBtn.disabled = true;
        purgeDeactivateMsg.textContent = 'Aplicando purga masiva...';

        try {
            const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/Admin/ExcelGenerator/WorkOrderPurge/DeactivateMissing', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...(token ? { 'RequestVerificationToken': token } : {})
                },
                body: JSON.stringify({ workOrders: latestMissingWos })
            });

            const payload = await response.json();
            if (!response.ok) {
                purgeDeactivateMsg.textContent = payload?.error || 'No se pudo completar la purga.';
                return;
            }

            purgeDeactivateMsg.textContent = `Purga completada. Solicitadas: ${payload.requested}. Actualizadas: ${payload.updated}.`;
            latestMissingWos = [];
            setKpiValue('kpiMissingInExcel', 0);
            renderMissingRows([]);
        } catch {
            purgeDeactivateMsg.textContent = 'Error inesperado durante la purga masiva.';
        } finally {
            purgeDeactivateBtn.disabled = false;
        }
    });
})();
</script>
}
