@model Trackii.Models.Admin.HardMod.HardModVm

@{
    ViewData["Title"] = "Hard Mod";
}

<div class="hardmod-page">
    <div class="card hardmod-hero">
        <div>
            <span class="search-section-label">Admin only</span>
            <h2>Hard Mod</h2>
            <p class="subtitle">Busca por No. de Work Order, ID de WIP item o producto. Si existe en WO/WIP/WIP Step Execution, se mostrará aquí para eliminarlo en cascada.</p>
        </div>
        <div class="alert alert-warning hardmod-warning-box">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>Esta acción elimina de forma permanente registros en <strong>work_order</strong>, <strong>wip_item</strong>, <strong>wip_step_execution</strong> y dependencias.</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-circle-check"></i>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert error">
            <i class="fa-solid fa-circle-xmark"></i>
            @Model.ErrorMessage
        </div>
    }

    <section class="card hardmod-card">
        <form method="get" action="/Admin/HardMod" class="hardmod-form">
            <label for="search">Buscador único</label>
            <div class="hardmod-input-row">
                <input id="search"
                       name="search"
                       value="@Model.Search"
                       type="text"
                       class="input"
                       placeholder="No. WO, ID de wip_item, ID de step execution o producto"
                       required />
                <button type="submit" class="btn btn-secondary">Buscar</button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.SearchMessage))
        {
            <div class="hardmod-lookup-message">@Model.SearchMessage</div>
        }

        @if (!Model.Results.Any())
        {
            <div class="search-empty-state compact">
                <i class="fa-regular fa-hard-drive"></i>
                <div>
                    <strong>Sin resultados cargados.</strong>
                    <p>Ingresa un criterio para localizar coincidencias en work_order, wip_item y wip_step_execution.</p>
                </div>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="table hardmod-results-table">
                    <thead>
                        <tr>
                            <th>WO ID</th>
                            <th>No. Orden</th>
                            <th>Producto</th>
                            <th>Existe en tablas</th>
                            <th>WIP items</th>
                            <th>WIP step execution</th>
                            <th>IDs WIP item</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Results)
                        {
                            <tr>
                                <td>@row.WorkOrderId</td>
                                <td>@row.WorkOrderNumber</td>
                                <td>@row.ProductPartNumber</td>
                                <td>
                                    <div class="hardmod-table-badges">
                                        <span class="table-badge @(row.ExistsInWorkOrder ? "on" : "off")">work_order</span>
                                        <span class="table-badge @(row.ExistsInWipItem ? "on" : "off")">wip_item</span>
                                        <span class="table-badge @(row.ExistsInWipStepExecution ? "on" : "off")">wip_step_execution</span>
                                    </div>
                                </td>
                                <td>@row.WipItemsCount</td>
                                <td>@row.WipStepExecutionsCount</td>
                                <td>@row.WipItemIdsPreview</td>
                                <td>
                                    <form method="post"
                                          action="/Admin/HardMod/DeleteByWorkOrder"
                                          onsubmit="return confirm('Se eliminará este elemento en work_order, wip_item, wip_step_execution y dependencias. ¿Deseas continuar?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="workOrderId" value="@row.WorkOrderId" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fa-solid fa-trash"></i>
                                            Hard delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
