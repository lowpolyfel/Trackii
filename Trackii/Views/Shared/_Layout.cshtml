@using Microsoft.AspNetCore.Identity
@inject IHttpContextAccessor HttpContextAccessor
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"]?.ToString() ?? "Panel";
    var username = HttpContextAccessor.HttpContext?.User?.Identity?.Name ?? "Usuario";
    var userInitial = string.IsNullOrWhiteSpace(username) ? "U" : username.Substring(0, 1).ToUpperInvariant();
    var isAdmin = User.IsInRole("Admin");
    var isEngineering = User.IsInRole("Engineering") || User.IsInRole("Ingenieria");
    var isGerencia = User.IsInRole("Gerencia");
    var orderSearchTerm = Context.Request.Query["q"].ToString();
    var altasBajasControllers = new[] { "AltasBajas", "Area", "Family", "Subfamily", "Product", "Route", "UnregisteredParts", "HardMod", "User", "Location", "Device", "Role", "ViewCatalog", "AdminWip", "ExcelGenerator", "WorkOrderReactivation" };
    var isAltasBajasActive = altasBajasControllers.Contains(currentController);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle - Trackii</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="~/Assets/Img/logo_trackii.png" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

</head>
<body>

    <div class="app-shell">

        <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mainSidebar">
            <i class="fa-solid fa-bars"></i>
        </button>

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="mainSidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand-mark">T</div>
                <div>
                    <span class="logo">Trackii</span>
                    <small>TT Electronics Workspace</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (isAdmin)
                {
                    <a asp-controller="Lobby" asp-action="Index" class="@(currentController == "Lobby" ? "active" : string.Empty)">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Lobby</span>
                    </a>
                }

                @if (isAdmin || isEngineering || isGerencia)
                {
                    <a asp-controller="Gerencia" asp-action="Index" class="@(currentController == "Gerencia" && currentAction == "Index" ? "active" : string.Empty)">
                        <i class="fa-solid fa-clipboard-check"></i>
                        <span>Gerencia</span>
                    </a>
                }

                @if (isAdmin || isEngineering || isGerencia)
                {
                    <a asp-controller="Gerencia" asp-action="InventarioReal" class="@(currentController == "Gerencia" && (currentAction == "InventarioReal" || currentAction == "Lobby" || currentAction == "Index") ? "active" : string.Empty)">
                        <i class="fa-solid fa-table"></i>
                        <span>INVENTARIO REAL</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="BackendLobby" class="@(currentController == "Gerencia" && currentAction == "BackendLobby" ? "active" : string.Empty)">
                        <i class="fa-solid fa-table-cells"></i>
                        <span>Lobby gerencia</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="OrderSearch" class="@(currentController == "Gerencia" && currentAction == "OrderSearch" ? "active" : string.Empty)">
                        <i class="fa-solid fa-magnifying-glass-chart"></i>
                        <span>Buscador órdenes</span>
                    </a>
                }

                @if (isAdmin || isGerencia)
                {
                    <a asp-controller="Gerencia" asp-action="BackendLobby" class="@(currentController == "Gerencia" && currentAction == "BackendLobby" ? "active" : string.Empty)">
                        <i class="fa-solid fa-table-cells"></i>
                        <span>Lobby gerencia</span>
                    </a>
                }

                @if (isAdmin || isGerencia)
                {
                    <a asp-controller="Gerencia" asp-action="ActiveOrders" class="@(currentController == "Gerencia" && currentAction == "ActiveOrders" ? "active" : string.Empty)">
                        <i class="fa-solid fa-list-check"></i>
                        <span>Órdenes activas</span>
                    </a>
                }

                @if (isAdmin)
                {
                    <a asp-controller="Gerencia" asp-action="WorkOrders" class="@(currentController == "Gerencia" && currentAction == "WorkOrders" ? "active" : string.Empty)">
                        <i class="fa-solid fa-clipboard-list"></i>
                        <span>Detalle órdenes</span>
                    </a>
                }

                @if (isAdmin)
                {
                    <a asp-controller="Gerencia" asp-action="Wip" class="@(currentController == "Gerencia" && currentAction == "Wip" ? "active" : string.Empty)">
                        <i class="fa-solid fa-boxes-stacked"></i>
                        <span>WIP detalle</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="ScanEvents" class="@(currentController == "Gerencia" && currentAction == "ScanEvents" ? "active" : string.Empty)">
                        <i class="fa-solid fa-barcode"></i>
                        <span>Eventos de scan</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="Production" class="@(currentController == "Gerencia" && currentAction == "Production" ? "active" : string.Empty)">
                        <i class="fa-solid fa-gears"></i>
                        <span>Producción</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="WeeklyOutput" class="@(currentController == "Gerencia" && currentAction == "WeeklyOutput" ? "active" : string.Empty)">
                        <i class="fa-solid fa-calendar-week"></i>
                        <span>Salida semanal</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="ScrapCauses" class="@(currentController == "Gerencia" && currentAction == "ScrapCauses" ? "active" : string.Empty)">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>Causas scrap</span>
                    </a>
                }

                @if (isAdmin || isEngineering || isGerencia)
                {
                    <a asp-controller="Gerencia" asp-action="ErrorCauses" class="@(currentController == "Gerencia" && currentAction == "ErrorCauses" ? "active" : string.Empty)">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>Causas de errores</span>
                    </a>
                }

                @if (isAdmin || isEngineering)
                {
                    <a asp-controller="Gerencia" asp-action="DiscreteMap" class="@(currentController == "Gerencia" && currentAction == "DiscreteMap" ? "active" : string.Empty)">
                        <i class="fa-solid fa-chart-column"></i>
                        <span>Mapa de discretos</span>
                    </a>

                    <a asp-controller="OrderTools" asp-action="Activate" class="@(currentController == "OrderTools" && currentAction == "Activate" ? "active" : string.Empty)">
                        <i class="fa-solid fa-play"></i>
                        <span>Activar órdenes</span>
                    </a>

                    <a asp-controller="OrderTools" asp-action="EditPieces" class="@(currentController == "OrderTools" && currentAction == "EditPieces" ? "active" : string.Empty)">
                        <i class="fa-solid fa-screwdriver-wrench"></i>
                        <span>Modificar piezas</span>
                    </a>

                    <a asp-controller="ExcelGenerator" asp-action="Index" class="@(currentController == "ExcelGenerator" ? "active" : string.Empty)">
                        <i class="fa-solid fa-file-excel"></i>
                        <span>Generador de Excel</span>
                    </a>
                }

                @if (isAdmin)
                {
                    <a asp-controller="Gerencia" asp-action="DiscreteDailyPanels" class="@(currentController == "Gerencia" && currentAction == "DiscreteDailyPanels" ? "active" : string.Empty)">
                        <i class="fa-solid fa-table-cells-large"></i>
                        <span>Paneles diarios discretos</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="DailyTrend" class="@(currentController == "Gerencia" && currentAction == "DailyTrend" ? "active" : string.Empty)">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Tendencia diaria</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="Throughput" class="@(currentController == "Gerencia" && currentAction == "Throughput" ? "active" : string.Empty)">
                        <i class="fa-solid fa-chart-column"></i>
                        <span>Throughput</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="ReworkSummary" class="@(currentController == "Gerencia" && currentAction == "ReworkSummary" ? "active" : string.Empty)">
                        <i class="fa-solid fa-rotate"></i>
                        <span>Rework</span>
                    </a>

                    <a asp-controller="Gerencia" asp-action="WoHealth" class="@(currentController == "Gerencia" && currentAction == "WoHealth" ? "active" : string.Empty)">
                        <i class="fa-solid fa-heart-pulse"></i>
                        <span>Salud de órdenes</span>
                    </a>

                    <a asp-controller="AltasBajas" asp-action="Index" class="@(isAltasBajasActive ? "active" : string.Empty)">
                        <i class="fa-solid fa-folder-tree"></i>
                        <span>Altas/Bajas</span>
                    </a>

                    <a asp-controller="AdminWip" asp-action="Index" class="@(currentController == "AdminWip" ? "active" : string.Empty)">
                        <i class="fa-solid fa-industry"></i>
                        <span>WIP Manager</span>
                    </a>

                    <a asp-controller="WorkOrderReactivation" asp-action="Index" class="@(currentController == "WorkOrderReactivation" ? "active" : string.Empty)">
                        <i class="fa-solid fa-file-circle-plus"></i>
                        <span>Alta de órdenes</span>
                    </a>
                }
            </nav>
        </aside>

        <div class="main">
            <header class="topbar">
                <div class="topbar-copy">
                    <span class="topbar-kicker">Trackii workspace</span>
                    <div class="topbar-left">
                        <h1>@pageTitle</h1>
                        <p>Operación organizada con una interfaz limpia y productiva.</p>
                    </div>
                </div>

                @if (isAdmin || isEngineering || isGerencia)
                {
                    <form asp-controller="Gerencia" asp-action="OrderSearch" method="get" class="topbar-search">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="search" name="q" placeholder="Buscar orden en inventario real..." autocomplete="off" value="@orderSearchTerm" />
                    </form>
                }

                <div class="topbar-right">
                    <span class="user-pill">
                        <span class="user-avatar">@userInitial</span>
                        <span class="user-copy">
                            <strong>@username</strong>
                            <small>Sesión activa</small>
                        </span>
                    </span>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout" title="Cerrar sesión">
                            <i class="fa-solid fa-right-from-bracket"></i>
                        </button>
                    </form>
                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
