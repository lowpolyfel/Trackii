@model Trackii.Models.Lobby.AdminLobbyVm

@{
    ViewData["Title"] = "Lobby Administrador";
}

<div class="dashboard">
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Areas</div>
                <div class="kpi-value">@Model.AreasCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-diagram-project"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Families</div>
                <div class="kpi-value">@Model.FamiliesCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-sitemap"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Subfamilies</div>
                <div class="kpi-value">@Model.SubfamiliesCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-box"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Products</div>
                <div class="kpi-value">@Model.ProductsCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-route"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Routes</div>
                <div class="kpi-value">@Model.RoutesCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-location-dot"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Localidades</div>
                <div class="kpi-value">@Model.LocationsCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Usuarios</div>
                <div class="kpi-value">@Model.UsersCount</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="fa-solid fa-tablet-screen-button"></i>
            </div>
            <div class="kpi-content">
                <div class="kpi-title">Dispositivos activos</div>
                <div class="kpi-value">@Model.ActiveDevicesCount</div>
            </div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="card admin-devices-card">
            <div class="admin-devices-header">
                <div>
                    <h3>Gestión rápida de dispositivos</h3>
                    <p class="subtitle">Visualiza dispositivos, cuenta asociada (último usuario que escaneó en ese dispositivo), contraseña enmascarada y cambia la localidad en un clic.</p>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="table admin-devices-table">
                    <thead>
                        <tr>
                            <th>Estado</th>
                            <th>UID</th>
                            <th>Nombre</th>
                            <th>Cuenta asociada</th>
                            <th>Contraseña</th>
                            <th>Localidad actual</th>
                            <th>Cambiar localidad</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ActiveDevices.Any())
                        {
                            <tr>
                                <td colspan="7" class="empty">No hay dispositivos registrados</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var device in Model.ActiveDevices)
                            {
                                <tr>
                                    <td>
                                        <span class="device-state @(device.Active ? "is-active" : "is-inactive")">
                                            @(device.Active ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td>@device.DeviceUid</td>
                                    <td>@(string.IsNullOrWhiteSpace(device.Name) ? "-" : device.Name)</td>
                                    <td>@device.AccountUsername</td>
                                    <td>
                                        <code>@device.PasswordMask</code>
                                    </td>
                                    <td class="device-location-current">@device.Location</td>
                                    <td>
                                        <form asp-controller="Lobby"
                                              asp-action="UpdateAdminDeviceLocation"
                                              method="post"
                                              class="device-location-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="deviceId" value="@device.DeviceId" />
                                            <select name="locationId" class="device-location-select">
                                                @foreach (var location in Model.Locations)
                                                {
                                                    <option value="@location.Id" selected="@(device.LocationId == location.Id)">
                                                        @location.Name
                                                    </option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <h3>Usuarios activos</h3>
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Rol</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ActiveUsers.Any())
                        {
                            <tr>
                                <td colspan="2" class="empty">No hay usuarios activos</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model.ActiveUsers)
                            {
                                <tr>
                                    <td>@user.Username</td>
                                    <td>@user.Role</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
