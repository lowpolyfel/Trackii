@model Trackii.Models.Engineering.EngineeringActiveOrdersVm

@{
    ViewData["Title"] = "Órdenes activas";
}

<div class="dashboard">
    <div class="page-header">
        <div>
            <h2>Dashboard de órdenes activas</h2>
            <p class="subtitle">Clasifica órdenes por familia, subfamilia, localidad y ruta para detectar carga y destino operativo.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Lobby" asp-action="Index" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i>
                Volver al lobby
            </a>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-list-check"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Órdenes activas</div>
                <div class="kpi-value">@Model.ActiveOrdersCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-layer-group"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Familias involucradas</div>
                <div class="kpi-value">@Model.DistinctFamiliesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-sitemap"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Subfamilias activas</div>
                <div class="kpi-value">@Model.DistinctSubfamiliesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-route"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Rutas activas</div>
                <div class="kpi-value">@Model.DistinctRoutesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Localidades activas</div>
                <div class="kpi-value">@Model.DistinctLocationsCount</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="page-header">
            <div>
                <h3>Filtros de clasificación</h3>
                <p class="subtitle">Usa las listas desplegables para ver qué órdenes van por una familia, ruta o localidad específica.</p>
            </div>
        </div>

        <form method="get" class="filters">
            <input type="search" name="search" value="@Model.Search" placeholder="Buscar no. de orden o producto..." />

            <select name="status">
                <option value="">Todos los estados</option>
                <option value="OPEN" selected="@(Model.Status == "OPEN")">Activa</option>
                <option value="IN_PROGRESS" selected="@(Model.Status == "IN_PROGRESS")">En progreso</option>
            </select>

            <select name="familyId" id="familyFilter">
                <option value="">Todas las familias</option>
                @foreach (var item in Model.Families)
                {
                    <option value="@item.Id" selected="@(Model.FamilyId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <select name="subfamilyId" id="subfamilyFilter">
                <option value="">Todas las subfamilias</option>
                @foreach (var item in Model.Subfamilies)
                {
                    <option value="@item.Id"
                            data-family-id="@item.FamilyId"
                            selected="@(Model.SubfamilyId == item.Id)">
                        @item.Name (@item.Count)
                    </option>
                }
            </select>

            <input type="hidden" name="focusSubfamilyId" value="@Model.FocusSubfamilyId" />

            <select name="routeId">
                <option value="">Todas las rutas</option>
                @foreach (var item in Model.Routes)
                {
                    <option value="@item.Id" selected="@(Model.RouteId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <select name="locationId">
                <option value="">Todas las localidades</option>
                @foreach (var item in Model.Locations)
                {
                    <option value="@item.Id" selected="@(Model.LocationId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <button type="submit" class="btn btn-primary">Aplicar filtros</button>
            <a asp-controller="Lobby" asp-action="EngineeringOrders" class="btn btn-secondary">Limpiar</a>
        </form>
    </div>

    <div class="card" id="subfamily-flow">
        <div class="page-header">
            <div>
                <h3>Localidad actual y siguiente paso por subfamilia</h3>
                <p class="subtitle">Selecciona una subfamilia para ver todas sus órdenes activas, en qué localidad están y cuál será la siguiente localidad de su ruta.</p>
            </div>
        </div>

        <form method="get" class="filters">
            <input type="hidden" name="search" value="@Model.Search" />
            <input type="hidden" name="status" value="@Model.Status" />
            <input type="hidden" name="familyId" value="@Model.FamilyId" />
            <input type="hidden" name="subfamilyId" value="@Model.SubfamilyId" />
            <input type="hidden" name="routeId" value="@Model.RouteId" />
            <input type="hidden" name="locationId" value="@Model.LocationId" />

            <select name="focusSubfamilyId" id="focusSubfamilyFilter">
                <option value="">Selecciona una subfamilia</option>
                @foreach (var item in Model.Subfamilies)
                {
                    <option value="@item.Id"
                            data-family-id="@item.FamilyId"
                            selected="@(Model.FocusSubfamilyId == item.Id)">
                        @item.Name (@item.Count)
                    </option>
                }
            </select>

            <button type="submit" class="btn btn-primary">Ver flujo</button>
            <a asp-controller="Lobby" asp-action="EngineeringOrders" class="btn btn-secondary">Restablecer tablero</a>
        </form>

        @if (!Model.FocusSubfamilyId.HasValue)
        {
            <div class="empty">Selecciona una subfamilia para desplegar sus órdenes y el siguiente paso de ruta.</div>
        }
        else if (!Model.FocusSubfamilyItems.Any())
        {
            <div class="empty">No hay órdenes activas para la subfamilia seleccionada.</div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="table js-groupable-table" id="focusSubfamilyTable">
                    <thead>
                        <tr>
                            <th>No. de orden</th>
                            <th>Producto</th>
                            <th>Localidad actual</th>
                            <th>
                                <button type="button"
                                        class="group-toggle"
                                        id="toggleNextLocationGrouping"
                                        aria-pressed="false"
                                        title="Agrupar por siguiente localidad">
                                    <i class="fa-solid fa-layer-group"></i>
                                </button>
                                Siguiente localidad
                            </th>
                            <th>Ruta</th>
                            <th class="text-right">Días</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.FocusSubfamilyItems)
                        {
                            <tr data-next-location="@item.NextLocation" data-current-location="@item.Location" data-wo="@item.WoNumber">
                                <td>@item.WoNumber</td>
                                <td>@item.Product</td>
                                <td>@item.Location</td>
                                <td>@item.NextLocation</td>
                                <td>@item.Route</td>
                                <td class="text-right">@(item.AgeDays?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="engineering-summary-grid">
        <div class="card">
            <h3>Órdenes por familia</h3>
            @if (!Model.FamilySummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.FamilySummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por subfamilia</h3>
            @if (!Model.SubfamilySummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.SubfamilySummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por localidad</h3>
            @if (!Model.LocationSummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.LocationSummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por ruta</h3>
            @if (!Model.RouteSummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.RouteSummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="card">
        <div class="page-header">
            <div>
                <h3>Listado filtrado de órdenes activas</h3>
                <p class="subtitle">Aquí puedes ver exactamente cuáles órdenes pertenecen a una familia, subfamilia, ruta o localidad seleccionada.</p>
            </div>
            <div class="header-actions">
                <button type="button" class="btn btn-secondary" id="exportFilteredOrdersCsv">
                    <i class="fa-solid fa-file-csv"></i>
                    Exportar CSV
                </button>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table" id="filteredOrdersTable">
                <thead>
                    <tr>
                        <th><button type="button" class="sort-button" data-sort-key="wo" data-sort-type="number">No. de orden</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="product" data-sort-type="text">Producto</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="status" data-sort-type="text">Estado</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="family" data-sort-type="text">Familia</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="subfamily" data-sort-type="text">Subfamilia</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="route" data-sort-type="text">Ruta</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="location" data-sort-type="text">Localidad</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="nextLocation" data-sort-type="text">Siguiente localidad</button></th>
                        <th><button type="button" class="sort-button" data-sort-key="wipStart" data-sort-type="date">Inicio WIP</button></th>
                        <th class="text-right"><button type="button" class="sort-button sort-button-right" data-sort-key="ageDays" data-sort-type="number">Días</button></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="10" class="empty">No hay órdenes que coincidan con los filtros seleccionados.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr data-wo="@item.WoNumber"
                                data-product="@item.Product"
                                data-status="@UiTextHelper.NormalizeStatus(item.Status)"
                                data-family="@item.Family"
                                data-subfamily="@item.Subfamily"
                                data-route="@item.Route"
                                data-location="@item.Location"
                                data-next-location="@item.NextLocation"
                                data-wip-start="@(item.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? string.Empty)"
                                data-age-days="@(item.AgeDays?.ToString() ?? string.Empty)">
                                <td>@item.WoNumber</td>
                                <td>@item.Product</td>
                                <td>@UiTextHelper.NormalizeStatus(item.Status)</td>
                                <td>@item.Family</td>
                                <td>@item.Subfamily</td>
                                <td>@item.Route</td>
                                <td>@item.Location</td>
                                <td>@item.NextLocation</td>
                                <td>@(item.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td class="text-right">@(item.AgeDays?.ToString() ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const familySelect = document.getElementById("familyFilter");
            const subfamilySelect = document.getElementById("subfamilyFilter");
            const focusSubfamilySelect = document.getElementById("focusSubfamilyFilter");
            if (!familySelect || !subfamilySelect) return;

            const options = Array.from(subfamilySelect.options);

            const filterSubfamilies = () => {
                const familyId = familySelect.value;
                options.forEach((option) => {
                    if (!option.value) {
                        option.hidden = false;
                        return;
                    }

                    option.hidden = !!familyId && option.dataset.familyId !== familyId;
                });

                const selected = subfamilySelect.selectedOptions[0];
                if (selected && selected.value && selected.hidden) {
                    subfamilySelect.value = "";
                }

                if (focusSubfamilySelect) {
                    const focusSelected = focusSubfamilySelect.selectedOptions[0];
                    Array.from(focusSubfamilySelect.options).forEach((option) => {
                        if (!option.value) {
                            option.hidden = false;
                            return;
                        }

                        option.hidden = !!familyId && option.dataset.familyId !== familyId;
                    });

                    if (focusSelected && focusSelected.value && focusSelected.hidden) {
                        focusSubfamilySelect.value = "";
                    }
                }
            };

            familySelect.addEventListener("change", filterSubfamilies);
            filterSubfamilies();
        })();

        (() => {
            const table = document.getElementById("focusSubfamilyTable");
            const toggle = document.getElementById("toggleNextLocationGrouping");
            if (!table || !toggle) return;

            const tbody = table.querySelector("tbody");
            const originalRows = Array.from(tbody.querySelectorAll("tr"));
            let grouped = false;

            const render = () => {
                tbody.innerHTML = "";

                if (!grouped) {
                    originalRows.forEach((row) => tbody.appendChild(row));
                    toggle.setAttribute("aria-pressed", "false");
                    toggle.classList.remove("active");
                    return;
                }

                const sortedRows = [...originalRows].sort((a, b) => {
                    const nextA = a.dataset.nextLocation || "";
                    const nextB = b.dataset.nextLocation || "";
                    if (nextA !== nextB) return nextA.localeCompare(nextB);

                    const currentA = a.dataset.currentLocation || "";
                    const currentB = b.dataset.currentLocation || "";
                    if (currentA !== currentB) return currentA.localeCompare(currentB);

                    return (a.dataset.wo || "").localeCompare(b.dataset.wo || "");
                });

                let currentGroup = "";
                sortedRows.forEach((row) => {
                    const nextLocation = row.dataset.nextLocation || "Sin siguiente localidad";
                    if (nextLocation !== currentGroup) {
                        currentGroup = nextLocation;
                        const groupRow = document.createElement("tr");
                        groupRow.className = "group-row";
                        groupRow.innerHTML = `<td colspan="6">Siguiente localidad: <strong>${currentGroup}</strong></td>`;
                        tbody.appendChild(groupRow);
                    }

                    tbody.appendChild(row);
                });

                toggle.setAttribute("aria-pressed", "true");
                toggle.classList.add("active");
            };

            toggle.addEventListener("click", () => {
                grouped = !grouped;
                render();
            });
        })();

        (() => {
            const table = document.getElementById("filteredOrdersTable");
            const exportButton = document.getElementById("exportFilteredOrdersCsv");
            if (!table) return;

            const tbody = table.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr")).filter((row) => !row.querySelector(".empty"));
            const sortButtons = Array.from(table.querySelectorAll(".sort-button"));
            let currentSortKey = "";
            let currentDirection = "asc";

            const getValue = (row, key, type) => {
                const attrName = key.replace(/[A-Z]/g, (match) => `-${match.toLowerCase()}`);
                const raw = row.dataset[attrName] ?? row.dataset[key] ?? "";

                if (type === "number") {
                    const parsed = Number(raw);
                    return Number.isNaN(parsed) ? Number.MIN_SAFE_INTEGER : parsed;
                }

                if (type === "date") {
                    const time = raw ? new Date(raw).getTime() : Number.MIN_SAFE_INTEGER;
                    return Number.isNaN(time) ? Number.MIN_SAFE_INTEGER : time;
                }

                return raw.toString().toLocaleLowerCase();
            };

            const renderRows = (sortedRows) => {
                tbody.innerHTML = "";
                sortedRows.forEach((row) => tbody.appendChild(row));
            };

            sortButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const { sortKey, sortType } = button.dataset;
                    if (!sortKey || !sortType || !rows.length) return;

                    if (currentSortKey === sortKey) {
                        currentDirection = currentDirection === "asc" ? "desc" : "asc";
                    } else {
                        currentSortKey = sortKey;
                        currentDirection = "asc";
                    }

                    const sortedRows = [...rows].sort((a, b) => {
                        const valueA = getValue(a, sortKey, sortType);
                        const valueB = getValue(b, sortKey, sortType);

                        if (valueA < valueB) return currentDirection === "asc" ? -1 : 1;
                        if (valueA > valueB) return currentDirection === "asc" ? 1 : -1;

                        const woA = Number(a.dataset.wo || 0);
                        const woB = Number(b.dataset.wo || 0);
                        return woA - woB;
                    });

                    sortButtons.forEach((item) => {
                        item.classList.remove("active", "desc");
                    });

                    button.classList.add("active");
                    if (currentDirection === "desc") {
                        button.classList.add("desc");
                    }

                    renderRows(sortedRows);
                });
            });

            if (exportButton) {
                exportButton.addEventListener("click", () => {
                    const headers = Array.from(table.querySelectorAll("thead th")).map((th) => th.innerText.trim());
                    const dataRows = Array.from(tbody.querySelectorAll("tr"));
                    if (!dataRows.length) return;

                    const csvLines = [
                        headers.join(","),
                        ...dataRows.map((row) => Array.from(row.children)
                            .map((cell) => `"${cell.innerText.replace(/"/g, '""')}"`)
                            .join(","))
                    ];

                    const blob = new Blob(["\uFEFF" + csvLines.join("\n")], { type: "text/csv;charset=utf-8;" });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement("a");
                    const timestamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, "-");

                    link.href = url;
                    link.download = `engineering-active-orders-${timestamp}.csv`;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    URL.revokeObjectURL(url);
                });
            }
        })();
    </script>
}
