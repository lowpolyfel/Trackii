@model Trackii.Models.Gerencia.GerenciaDiscreteMapVm
@using System.Globalization
@{
    ViewData["Title"] = "Mapa de Discretos";
    var spanish = new CultureInfo("es-MX");

    string ShortSubfamily(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "-";
        if (name.Length <= 14) return name;

        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length > 1)
        {
            var acronym = string.Concat(words.Select(word => char.ToUpperInvariant(word[0])));
            if (acronym.Length >= 2 && acronym.Length <= 8)
            {
                return acronym;
            }
        }

        return name[..12] + "…";
    }

    var shortNames = Model.Matrix.Subfamilies.ToDictionary(name => name, ShortSubfamily);
}

<div class="dashboard">
    <div class="page-header error-causes-header">
        <div>
            <h2>Mapa de Discretos (Inventario real)</h2>
            <p class="subtitle">Eje Y: localidades en rutas activas · Eje X: subfamilias. Corte al <strong>@Model.SnapshotDate.ToString("dddd dd MMM yyyy", spanish)</strong>.</p>
        </div>
        <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>

    <div class="card gerencia-weekly-card apple-card error-causes-card">
        <div class="card-heading">
            <h3>Filtros</h3>
            <span class="chip">Fecha de corte</span>
        </div>

        <form method="get" class="filters discrete-filters" style="display:flex;flex-wrap:wrap;gap:12px;align-items:end;">
            <div class="discrete-filter-field" style="min-width:220px;">
                <label for="periodType">Tipo de período</label>
                <select id="periodType" name="periodType">
                    <option value="day" selected="@(Model.PeriodType == "day")">Día</option>
                    <option value="week" selected="@(Model.PeriodType == "week")">Semana</option>
                    <option value="month" selected="@(Model.PeriodType == "month")">Mes</option>
                    <option value="custom" selected="@(Model.PeriodType == "custom")">Rango personalizado</option>
                    <option value="historic" selected="@(Model.PeriodType == "historic")">Histórico</option>
                </select>
            </div>

            <div class="discrete-filter-field period-field period-day" data-period="day">
                <label for="dayValue">Día</label>
                <input id="dayValue" type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="discrete-filter-field period-field period-week" data-period="week">
                <label for="weekValue">Semana ISO</label>
                <input id="weekValue" type="week" name="weekValue" value="@Model.WeekValue" />
            </div>

            <div class="discrete-filter-field period-field period-month" data-period="month">
                <label for="monthValue">Mes</label>
                <input id="monthValue" type="month" name="monthValue" value="@Model.MonthValue" />
            </div>

            <div class="discrete-filter-field period-field period-custom" data-period="custom">
                <label for="fromDate">Desde</label>
                <input id="fromDate" type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="discrete-filter-field period-field period-custom" data-period="custom">
                <label for="toDate">Hasta</label>
                <input id="toDate" type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
            </div>

            <button type="submit" class="btn btn-primary">Actualizar mapa</button>
        </form>

        <p class="subtitle">Periodo consultado: <strong>@Model.Matrix.StartDate.ToString("yyyy-MM-dd")</strong> a <strong>@Model.Matrix.EndDate.ToString("yyyy-MM-dd")</strong>. Se muestra el inventario real al cierre del día final.</p>
    </div>

    <section class="error-kpis" aria-label="Resumen inventario real">
        <article class="kpi-highlight apple-card error-kpi-card" style="display:flex;justify-content:space-between;gap:18px;align-items:flex-start;">
            <div>
                <span class="kpi-label">Total piezas</span>
                <strong class="kpi-value">@Model.Matrix.TotalPieces.ToString("N0")</strong>
            </div>
            <div>
                <span class="kpi-label">Total órdenes</span>
                <strong class="kpi-value">@Model.Matrix.TotalOrders.ToString("N0")</strong>
            </div>
            <small>Inventario real y órdenes del periodo seleccionado.</small>
        </article>
    </section>

    <div class="card gerencia-weekly-card apple-card error-causes-card discrete-map-card">
        <div class="card-heading">
            <h3>Mapa principal (PIEZAS)</h3>
            <span class="chip">Operativo</span>
        </div>
        <div class="table-wrapper discrete-map-wrapper">
            <table class="table gerencia-weekly-table discrete-map-table">
                <thead>
                    <tr>
                        <th>Localidad</th>
                        @foreach (var subfamily in Model.Matrix.Subfamilies)
                        {
                            <th title="@subfamily">@shortNames[subfamily]</th>
                        }
                        <th>Total piezas</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Matrix.Rows.Any())
                {
                    <tr>
                        <td colspan="@(Model.Matrix.Subfamilies.Count + 2)" class="empty">No hay localidades con rutas activas para el corte seleccionado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Matrix.Rows)
                    {
                        <tr>
                            <td>@row.Location</td>
                            @foreach (var cell in row.Cells)
                            {
                                <td>
                                    <a asp-controller="Gerencia"
                                       asp-action="DiscreteMapDetail"
                                       asp-route-location="@row.Location"
                                       asp-route-subfamily="@cell.Subfamily"
                                       asp-route-periodType="@Model.PeriodType"
                                       asp-route-weekValue="@Model.WeekValue"
                                       asp-route-monthValue="@Model.MonthValue"
                                       asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                       asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))">
                                        @cell.Pieces.ToString("N0")
                                    </a>
                                </td>
                            }
                            <td><strong>@row.TotalPieces.ToString("N0")</strong></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card gerencia-weekly-card apple-card error-causes-card discrete-map-card">
        <div class="card-heading">
            <h3>Mapa alternativo (ORDENES · work_orders)</h3>
            <span class="chip chip-muted">Alternativo</span>
        </div>
        <div class="table-wrapper discrete-map-wrapper">
            <table class="table gerencia-weekly-table discrete-map-table">
                <thead>
                    <tr>
                        <th>Localidad</th>
                        @foreach (var subfamily in Model.Matrix.Subfamilies)
                        {
                            <th title="@subfamily">@shortNames[subfamily]</th>
                        }
                        <th>Total órdenes</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Matrix.Rows.Any())
                {
                    <tr>
                        <td colspan="@(Model.Matrix.Subfamilies.Count + 2)" class="empty">No hay localidades con rutas activas para el corte seleccionado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Matrix.Rows)
                    {
                        <tr>
                            <td>@row.Location</td>
                            @foreach (var cell in row.Cells)
                            {
                                <td>
                                    <a asp-controller="Gerencia"
                                       asp-action="DiscreteMapDetail"
                                       asp-route-location="@row.Location"
                                       asp-route-subfamily="@cell.Subfamily"
                                       asp-route-periodType="@Model.PeriodType"
                                       asp-route-weekValue="@Model.WeekValue"
                                       asp-route-monthValue="@Model.MonthValue"
                                       asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                       asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))">
                                        @cell.Orders.ToString("N0")
                                    </a>
                                </td>
                            }
                            <td><strong>@row.TotalOrders.ToString("N0")</strong></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const periodType = document.getElementById('periodType');
            const fields = document.querySelectorAll('.period-field');
            if (!periodType || !fields.length) return;

            const toggleFields = () => {
                const selected = periodType.value;
                fields.forEach((field) => {
                    const visible = field.dataset.period === selected;
                    field.classList.toggle('is-visible', visible);
                    field.style.display = visible ? '' : 'none';
                    field.querySelector('input')?.toggleAttribute('disabled', !visible);
                });
            };

            periodType.addEventListener('change', toggleFields);
            toggleFields();
        })();
    </script>
}
