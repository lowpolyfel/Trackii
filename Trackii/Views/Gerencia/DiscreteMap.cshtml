@model Trackii.Models.Gerencia.GerenciaDiscreteMapVm
@using System.Globalization
@{
    ViewData["Title"] = "Mapa de Discretos";
    var spanish = new CultureInfo("es-MX");

    string ShortSubfamily(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "-";
        if (name.Length <= 14) return name;

        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length > 1)
        {
            var acronym = string.Concat(words.Select(word => char.ToUpperInvariant(word[0])));
            if (acronym.Length >= 2 && acronym.Length <= 8)
            {
                return acronym;
            }
        }

        return name[..12] + "…";
    }

    var shortNames = Model.Matrix.Subfamilies.ToDictionary(name => name, ShortSubfamily);
}

<div class="dashboard">
    <div class="page-header error-causes-header">
        <div>
            <h2>Mapa de Discretos (versión ejecutiva)</h2>
            <p class="subtitle">Corte al <strong>@Model.SnapshotDate.ToString("dddd dd MMM yyyy", spanish)</strong> · periodo: <strong>@Model.Matrix.StartDate.ToString("yyyy-MM-dd")</strong> a <strong>@Model.Matrix.EndDate.ToString("yyyy-MM-dd")</strong>.</p>
        </div>
        <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>

    <div class="card gerencia-weekly-card apple-card error-causes-card">
        <div class="card-heading">
            <h3>Rango rápido</h3>
            <span class="chip">All day / week / month / year</span>
        </div>

        <form method="get" class="quick-range-form">
            <div class="quick-range-buttons" role="group" aria-label="Rango rápido">
                <button class="btn @(Model.QuickRange == "day" ? "btn-primary" : "btn-secondary")" type="submit" name="periodType" value="day">All day</button>
                <button class="btn @(Model.QuickRange == "week" ? "btn-primary" : "btn-secondary")" type="submit" name="periodType" value="week">All week</button>
                <button class="btn @(Model.QuickRange == "month" ? "btn-primary" : "btn-secondary")" type="submit" name="periodType" value="month">All month</button>
                <button class="btn @(Model.QuickRange == "historic" ? "btn-primary" : "btn-secondary")" type="submit" name="periodType" value="historic">All year</button>
            </div>
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="metricView" value="@Model.MetricView" />
        </form>
    </div>

    <section class="error-kpis" aria-label="Resumen inventario real">
        <article class="kpi-highlight apple-card error-kpi-card discrete-kpi-grid">
            <div>
                <span class="kpi-label">Total piezas</span>
                <strong class="kpi-value">@Model.Matrix.TotalPieces.ToString("N0")</strong>
            </div>
            <div>
                <span class="kpi-label">Total órdenes</span>
                <strong class="kpi-value">@Model.Matrix.TotalOrders.ToString("N0")</strong>
            </div>
            <small>Subfamilias sin actividad ocultas automáticamente para reducir ruido visual.</small>
        </article>

        <article class="kpi-highlight apple-card error-kpi-card">
            <span class="kpi-label">Subfamilias ocultas</span>
            @if (!Model.HiddenSubfamilies.Any())
            {
                <p class="subtitle">Todas las subfamilias tienen órdenes o productos en este periodo.</p>
            }
            else
            {
                <p class="subtitle">Estas subfamilias no cuentan con ninguna orden y/o producto generado en este tiempo seleccionado:</p>
                <ul class="compact-list">
                    @foreach (var name in Model.HiddenSubfamilies)
                    {
                        <li>@name</li>
                    }
                </ul>
            }
        </article>
    </section>

    <div class="card gerencia-weekly-card apple-card error-causes-card discrete-map-card">
        <div class="card-heading">
            <h3>Mapa principal (PIEZAS)</h3>
            <span class="chip">Operativo</span>
        </div>
        <div class="table-wrapper discrete-map-wrapper">
            <table class="table gerencia-weekly-table discrete-map-table">
                <thead>
                    <tr>
                        <th>Localidad</th>
                        @foreach (var subfamily in Model.Matrix.Subfamilies)
                        {
                            <th title="@subfamily">@shortNames[subfamily]</th>
                        }
                        <th>Total piezas</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Matrix.Rows.Any())
                {
                    <tr>
                        <td colspan="@(Model.Matrix.Subfamilies.Count + 2)" class="empty">No hay localidades con rutas activas para el corte seleccionado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Matrix.Rows)
                    {
                        <tr>
                            <td>@row.Location</td>
                            @foreach (var cell in row.Cells)
                            {
                                var zeroClass = cell.Pieces == 0 ? "cell-zero" : string.Empty;
                                <td class="@zeroClass">
                                    @if (cell.Pieces == 0)
                                    {
                                        <span class="zero-mask" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <a asp-controller="Gerencia"
                                           asp-action="DiscreteMapDetail"
                                           asp-route-location="@row.Location"
                                           asp-route-subfamily="@cell.Subfamily"
                                           asp-route-periodType="@Model.PeriodType"
                                           asp-route-weekValue="@Model.WeekValue"
                                           asp-route-monthValue="@Model.MonthValue"
                                           asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                           asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                                           class="cell-link-strong">
                                            @cell.Pieces.ToString("N0")
                                        </a>
                                    }
                                </td>
                            }
                            <td><strong>@row.TotalPieces.ToString("N0")</strong></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
