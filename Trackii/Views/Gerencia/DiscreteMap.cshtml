@model Trackii.Models.Gerencia.GerenciaDiscreteMapVm
@using System.Globalization
@{
    ViewData["Title"] = "Mapa de Discretos";
    var spanish = new CultureInfo("es-MX");
}

<div class="dashboard">
    <div class="page-header">
        <div>
            <h2>Mapa de Discretos</h2>
            <p class="subtitle">Vista extendida con periodo configurable y navegación por día.</p>
        </div>
        <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>

    <div class="card">
        <form method="get" class="filters discrete-filters discrete-filters-enhanced">
            <div class="discrete-filter-field discrete-filter-main">
                <label for="periodType">Tipo de período</label>
                <select id="periodType" name="periodType">
                    <option value="week" selected="@(Model.PeriodType == "week")">Semana</option>
                    <option value="month" selected="@(Model.PeriodType == "month")">Mes</option>
                    <option value="custom" selected="@(Model.PeriodType == "custom")">Rango personalizado</option>
                </select>
                <small>Selecciona cómo quieres agrupar la vista del mapa.</small>
            </div>

            <div class="discrete-filter-grid">
                <div class="discrete-filter-field period-field period-week" data-period="week">
                    <label for="weekValue">Semana ISO</label>
                    <input id="weekValue" type="week" name="weekValue" value="@Model.WeekValue" />
                    <small>Ejemplo: semana 13 del año 2026.</small>
                </div>

                <div class="discrete-filter-field period-field period-month" data-period="month">
                    <label for="monthValue">Mes</label>
                    <input id="monthValue" type="month" name="monthValue" value="@Model.MonthValue" />
                    <small>Selecciona el mes completo a consultar.</small>
                </div>

                <div class="discrete-filter-field period-field period-custom" data-period="custom">
                    <label for="fromDate">Desde</label>
                    <input id="fromDate" type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                    <small>Fecha inicial del rango personalizado.</small>
                </div>

                <div class="discrete-filter-field period-field period-custom" data-period="custom">
                    <label for="toDate">Hasta</label>
                    <input id="toDate" type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                    <small>Fecha final del rango personalizado.</small>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Aplicar</button>
        </form>
    </div>

    <div class="card gerencia-weekly-card">
        <p class="subtitle">Período: <strong>@Model.Matrix.StartDate.ToString("yyyy-MM-dd")</strong> a <strong>@Model.Matrix.EndDate.ToString("yyyy-MM-dd")</strong>.</p>
        <div class="table-wrapper">
            <table class="table gerencia-weekly-table">
                <thead>
                    <tr>
                        <th>Día</th>
                        @foreach (var subfamily in Model.Matrix.Subfamilies)
                        {
                            <th>@subfamily</th>
                        }
                        <th>Total piezas</th>
                        <th>Total scrap</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Matrix.Rows)
                {
                    <tr>
                        <td><a asp-controller="Gerencia" asp-action="DiscreteDay" asp-route-day="@row.Day.ToString("yyyy-MM-dd")" class="day-link">@row.Day.ToString("dddd dd MMM", spanish)</a></td>
                        @foreach (var cell in row.Cells)
                        {
                            <td>
                                <span class="weekly-pill qty">@cell.Qty</span>
                                <span class="weekly-pill scrap">@cell.Scrap</span>
                            </td>
                        }
                        <td>@row.TotalQty</td>
                        <td>@row.TotalScrap</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const periodType = document.getElementById('periodType');
            const fields = document.querySelectorAll('.period-field');
            if (!periodType || !fields.length) return;

            const toggleFields = () => {
                const selected = periodType.value;
                fields.forEach((field) => {
                    const visible = field.dataset.period === selected;
                    field.classList.toggle('is-visible', visible);
                    field.querySelector('input')?.toggleAttribute('disabled', !visible);
                });
            };

            periodType.addEventListener('change', toggleFields);
            toggleFields();
        })();
    </script>
}
