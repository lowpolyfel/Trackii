@using System.Globalization
@model Trackii.Models.Gerencia.GerenciaBackendLobbyVm

@{
    ViewData["Title"] = "Lobby de Gerencia";
    var spanish = new CultureInfo("es-MX");
}

<div class="page-header error-causes-header">
    <div>
        <h2>Lobby de Gerencia · Discretos</h2>
        <p class="subtitle" style="margin:0;">Actualización en tiempo real al cargar la vista: <strong>@Model.SnapshotAtUtc.ToString("dddd dd MMM yyyy HH:mm:ss", spanish)</strong>.</p>
        <p class="subtitle" style="margin:0;">Corte de datos acumulado hasta: <strong>@Model.DataCutoffUtc.ToString("dddd dd MMM yyyy HH:mm:ss", spanish)</strong> (UTC).</p>
    </div>
    <a asp-controller="Gerencia" asp-action="DiscreteMap" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Ir a mapa</a>
</div>

<div class="table-wrapper discrete-map-wrapper" style="margin-top: 20px;">
    <table class="table gerencia-weekly-table discrete-map-table">
        <thead>
            <tr>
                <th>Localidad</th>
                <th>Familia</th>
                <th class="text-right">Piezas totales</th>
                <th class="text-right">Órdenes totales</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Groups.Any())
            {
                <tr>
                    <td colspan="4" class="text-center">Sin producción disponible.</td>
                </tr>
            }
            else
            {
                @foreach (var group in Model.Groups)
                {
                    <tr>
                        <td><strong>@group.LocationName</strong></td>
                        <td>@group.FamilyGroupName</td>
                        <td class="text-right">@group.Piezas.ToString("N0")</td>
                        <td class="text-right">@group.Ordenes.ToString("N0")</td>
                    </tr>
                }
            }
            <tr>
                <td colspan="2"><strong>Total global</strong></td>
                <td class="text-right"><strong>@Model.TotalPieces.ToString("N0")</strong></td>
                <td class="text-right"><strong>@Model.TotalOrders.ToString("N0")</strong></td>
            </tr>
        </tbody>
    </table>
</div>
