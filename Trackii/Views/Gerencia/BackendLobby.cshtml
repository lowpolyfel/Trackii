@using System.Globalization
@model Trackii.Models.Gerencia.GerenciaBackendLobbyVm

@{
    ViewData["Title"] = "Lobby de Gerencia";
    var spanish = new CultureInfo("es-MX");
}

<div class="page-header error-causes-header">
    <div>
        <h2>Lobby de Gerencia · Discretos</h2>
        <p class="subtitle" style="margin:0;">Actualización en tiempo real al cargar la vista: <strong>@Model.SnapshotAtUtc.ToString("dddd dd MMM yyyy HH:mm:ss", spanish)</strong>.</p>
        <p class="subtitle" style="margin:0;">Corte de datos acumulado hasta: <strong>@Model.DataCutoffUtc.ToString("dddd dd MMM yyyy HH:mm:ss", spanish)</strong> (UTC).</p>
    </div>
    <a asp-controller="Gerencia" asp-action="DiscreteMap" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Ir a mapa</a>
</div>

<div class="table-wrapper discrete-map-wrapper" style="margin-top: 20px;">
    <table class="table gerencia-weekly-table discrete-map-table">
        <thead>
            <tr>
                <th>META DIARIA</th>
                @foreach (var column in Model.Columns)
                {
                    <th class="text-right">
                        @(Model.DailyGoalsByColumn.TryGetValue(column, out var goal) && goal.HasValue ? goal.Value.ToString("N0") : "-")
                    </th>
                }
                <th class="text-right">@Model.DailyGoalsByColumn.Values.Where(v => v.HasValue).Sum(v => v!.Value).ToString("N0")</th>
            </tr>
            <tr>
                <th>LOCALIDAD</th>
                @foreach (var column in Model.Columns)
                {
                    <th>@column</th>
                }
                <th class="text-right">TOTAL LOCALIDAD</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Rows.Any())
            {
                <tr>
                    <td colspan="@(Model.Columns.Count + 2)" class="text-center">Sin producción disponible.</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td><strong>@row.LocationName</strong></td>
                        @foreach (var column in Model.Columns)
                        {
                            var qty = row.PiecesByColumn.TryGetValue(column, out var value) ? value : 0;
                            <td class="text-right">@(qty == 0 ? "-" : qty.ToString("N0"))</td>
                        }
                        <td class="text-right"><strong>@row.TotalPieces.ToString("N0")</strong></td>
                    </tr>
                }
            }
            <tr>
                <td><strong>Total</strong></td>
                @foreach (var column in Model.Columns)
                {
                    var total = Model.TotalsByColumn.TryGetValue(column, out var value) ? value : 0;
                    <td class="text-right"><strong>@total.ToString("N0")</strong></td>
                }
                <td class="text-right"><strong>@Model.GrandTotalPieces.ToString("N0")</strong></td>
            </tr>
        </tbody>
    </table>
</div>
