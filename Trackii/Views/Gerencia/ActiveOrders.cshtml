@using System.Text.Json
@model Trackii.Models.Gerencia.GerenciaActiveOrdersVm
@{
    ViewData["Title"] = "Órdenes activas - Detalle";
    var selectedLocation = (ViewBag.SelectedLocation as string ?? string.Empty).Trim();
    var selectedSubfamily = (ViewBag.SelectedSubfamily as string ?? string.Empty).Trim();

    var allOrders = Model.ActiveOrders.Concat(Model.InProgressOrders).ToList();
    var locationOptions = allOrders
        .Select(x => x.CurrentLocation)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
    var subfamilyOptions = allOrders
        .Select(x => x.Subfamily)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
    bool MatchesFilters(Trackii.Models.Gerencia.WorkOrderVm order)
    {
        var locationMatch = string.IsNullOrWhiteSpace(selectedLocation)
            || string.Equals(order.CurrentLocation ?? string.Empty, selectedLocation, StringComparison.OrdinalIgnoreCase);
        var subfamilyMatch = string.IsNullOrWhiteSpace(selectedSubfamily)
            || string.Equals(order.Subfamily, selectedSubfamily, StringComparison.OrdinalIgnoreCase);
        return locationMatch && subfamilyMatch;
    }
    var filteredOpenOrders = Model.ActiveOrders.Where(MatchesFilters).ToList();
    var filteredInProgressOrders = Model.InProgressOrders.Where(MatchesFilters).ToList();
    var filteredOrders = filteredOpenOrders.Concat(filteredInProgressOrders).ToList();

    var recentThreshold = DateTime.UtcNow.AddHours(-24);
    var recentCreatedCount = filteredOrders.Count(x => x.WipCreatedAt.HasValue && x.WipCreatedAt.Value >= recentThreshold);
    var withLocationCount = filteredOrders.Count(x => !string.IsNullOrWhiteSpace(x.CurrentLocation));

    var locationRows = filteredOrders
        .Where(x => !string.IsNullOrWhiteSpace(x.CurrentLocation))
        .GroupBy(x => x.CurrentLocation!)
        .Select(g => new { Location = g.Key, Count = g.Count() })
        .OrderByDescending(x => x.Count)
        .ThenBy(x => x.Location)
        .Take(10)
        .ToList();

    var locationLabels = locationRows.Select(x => x.Location).ToList();
    var locationValues = locationRows.Select(x => x.Count).ToList();

    var statusRows = new[]
    {
        new { Label = "Abiertas", Count = filteredOpenOrders.Count },
        new { Label = "En progreso", Count = filteredInProgressOrders.Count }
    };

    var statusLabels = statusRows.Select(x => x.Label).ToList();
    var statusValues = statusRows.Select(x => x.Count).ToList();

    var dailyRows = filteredOrders
        .Where(x => x.WipCreatedAt.HasValue)
        .GroupBy(x => x.WipCreatedAt!.Value.Date)
        .Select(g => new { Day = g.Key, Count = g.Count() })
        .OrderByDescending(x => x.Day)
        .Take(7)
        .OrderBy(x => x.Day)
        .ToList();

    var dailyLabels = dailyRows.Select(x => x.Day.ToString("MM-dd")).ToList();
    var dailyValues = dailyRows.Select(x => x.Count).ToList();
}
<div class="dashboard">
    <div class="page-header error-causes-header">
        <div>
            <h2>Órdenes activas detalladas</h2>
            <p class="subtitle">Panel operativo por localidad y subfamilia con fecha, cantidad y detalle de órdenes activas.</p>
        </div>
        <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>

    <div class="card apple-card error-causes-card">
        <form method="get" class="filters discrete-filters" style="display:flex;flex-wrap:wrap;gap:12px;align-items:end;">
            <div class="discrete-filter-field" style="min-width:220px;">
                <label for="location">Localidad</label>
                <select id="location" name="location">
                    <option value="">Todas</option>
                    @foreach (var option in locationOptions)
                    {
                        if (string.Equals(option, selectedLocation, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option" selected>@option</option>
                        }
                        else
                        {
                            <option value="@option">@option</option>
                        }
                    }
                </select>
            </div>
            <div class="discrete-filter-field" style="min-width:220px;">
                <label for="subfamily">Subfamilia</label>
                <select id="subfamily" name="subfamily">
                    <option value="">Todas</option>
                    @foreach (var option in subfamilyOptions)
                    {
                        if (string.Equals(option, selectedSubfamily, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option" selected>@option</option>
                        }
                        else
                        {
                            <option value="@option">@option</option>
                        }
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Aplicar filtros</button>
            <a asp-action="ActiveOrders" class="btn btn-secondary">Limpiar</a>
        </form>
    </div>

    <section class="error-kpis" aria-label="KPIs de órdenes activas">
        <article class="kpi-highlight apple-card error-kpi-card">
            <span class="kpi-label">Órdenes abiertas</span>
            <strong class="kpi-value">@filteredOpenOrders.Count.ToString("N0")</strong>
            <small>Estado OPEN.</small>
        </article>
        <article class="kpi-highlight apple-card error-kpi-card">
            <span class="kpi-label">Órdenes en progreso</span>
            <strong class="kpi-value">@filteredInProgressOrders.Count.ToString("N0")</strong>
            <small>Estado IN_PROGRESS.</small>
        </article>
        <article class="kpi-highlight apple-card error-kpi-card">
            <span class="kpi-label">Recién creadas (24h)</span>
            <strong class="kpi-value">@recentCreatedCount.ToString("N0")</strong>
            <small>Basado en fecha de creación de WIP.</small>
        </article>
        <article class="kpi-highlight apple-card error-kpi-card">
            <span class="kpi-label">Con localidad asignada</span>
            <strong class="kpi-value">@withLocationCount.ToString("N0")</strong>
            <small>Sobre @filteredOrders.Count órdenes activas filtradas.</small>
        </article>
    </section>

    <div class="chart-grid error-causes-grid">
        <div class="card chart-card apple-card error-causes-card">
            <div class="card-heading">
                <h3>Órdenes activas por localidad</h3>
                <span class="chip">Top 10</span>
            </div>
            <div id="activeOrdersLocationChart" class="chart-host chart-host-lg"></div>
        </div>
        <div class="card chart-card apple-card error-causes-card">
            <div class="card-heading">
                <h3>Distribución de estados</h3>
                <span class="chip chip-muted">Abiertas vs progreso</span>
            </div>
            <div id="activeOrdersStatusChart" class="chart-host chart-host-lg"></div>
        </div>
    </div>

    <div class="chart-grid error-causes-grid">
        <div class="card chart-card apple-card error-causes-card">
            <div class="card-heading">
                <h3>Tendencia de creación (7 días)</h3>
                <span class="chip chip-muted">Recientes</span>
            </div>
            <div id="activeOrdersTrendChart" class="chart-host chart-host-lg"></div>
        </div>
        <div class="card apple-card error-causes-card">
            <div class="card-heading">
                <h3>Abiertas</h3>
                <span class="chip">OPEN</span>
            </div>
            <div class="table-wrapper table-wrapper-tall">
                <table class="table">
                    <thead><tr><th>WO</th><th>Producto</th><th>Subfamilia</th><th>Cantidad</th><th>Fecha</th><th>Estado</th><th>WIP</th><th>Localidad</th></tr></thead>
                    <tbody>
                        @if (!filteredOpenOrders.Any())
                        {
                            <tr><td colspan="8" class="empty">No hay órdenes abiertas para los filtros seleccionados.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in filteredOpenOrders)
                            {
                                <tr>
                                    <td>@item.WoNumber</td>
                                    <td>@item.Product</td>
                                    <td>@item.Subfamily</td>
                                    <td>@item.Qty.ToString("N0")</td>
                                    <td>@(item.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td><span class="chip chip-muted">@UiTextHelper.NormalizeStatus(item.Status)</span></td>
                                    <td>@(item.WipItemId?.ToString() ?? "-")</td>
                                    <td>@(item.CurrentLocation ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card apple-card error-causes-card">
        <div class="card-heading">
            <h3>En progreso</h3>
            <span class="chip">IN_PROGRESS</span>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <thead><tr><th>WO</th><th>Producto</th><th>Subfamilia</th><th>Cantidad</th><th>Fecha</th><th>Estado</th><th>WIP</th><th>Estado WIP</th><th>Localidad</th></tr></thead>
                <tbody>
                    @if (!filteredInProgressOrders.Any())
                    {
                        <tr><td colspan="9" class="empty">No hay órdenes en progreso para los filtros seleccionados.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in filteredInProgressOrders)
                        {
                            <tr>
                                <td>@item.WoNumber</td>
                                <td>@item.Product</td>
                                <td>@item.Subfamily</td>
                                <td>@item.Qty.ToString("N0")</td>
                                <td>@(item.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td><span class="chip chip-muted">@UiTextHelper.NormalizeStatus(item.Status)</span></td>
                                <td>@(item.WipItemId?.ToString() ?? "-")</td>
                                <td>@(item.WipStatus is null ? "-" : UiTextHelper.NormalizeStatus(item.WipStatus))</td>
                                <td>@(item.CurrentLocation ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
const locationLabels = @Html.Raw(JsonSerializer.Serialize(locationLabels));
const locationValues = @Html.Raw(JsonSerializer.Serialize(locationValues));
const statusLabels = @Html.Raw(JsonSerializer.Serialize(statusLabels));
const statusValues = @Html.Raw(JsonSerializer.Serialize(statusValues));
const dailyLabels = @Html.Raw(JsonSerializer.Serialize(dailyLabels));
const dailyValues = @Html.Raw(JsonSerializer.Serialize(dailyValues));

const sharedChartConfig = {
    chart: {
        height: 360,
        toolbar: { show: false },
        fontFamily: 'Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif',
        animations: { enabled: true, easing: 'easeinout', speed: 420 }
    },
    noData: { text: 'Sin datos para mostrar', align: 'center', verticalAlign: 'middle' },
    grid: { borderColor: 'rgba(80, 110, 150, 0.12)', strokeDashArray: 4 },
    dataLabels: { enabled: false },
    tooltip: { theme: 'light' }
};

new ApexCharts(document.getElementById('activeOrdersLocationChart'), {
    ...sharedChartConfig,
    chart: { ...sharedChartConfig.chart, type: 'bar' },
    series: [{ name: 'Órdenes', data: locationValues }],
    colors: ['#2d8bff'],
    plotOptions: { bar: { borderRadius: 9, horizontal: true, barHeight: '56%' } },
    legend: { show: false },
    xaxis: {
        categories: locationLabels,
        labels: { formatter: value => Math.round(value).toLocaleString('es-MX'), style: { colors: '#5f7392' } }
    },
    yaxis: { labels: { style: { colors: '#4d6283', fontSize: '12px', fontWeight: 600 } } }
}).render();

new ApexCharts(document.getElementById('activeOrdersStatusChart'), {
    ...sharedChartConfig,
    chart: { ...sharedChartConfig.chart, type: 'donut' },
    labels: statusLabels,
    series: statusValues,
    colors: ['#0ea5e9', '#7c3aed'],
    legend: { position: 'bottom' },
    plotOptions: {
        pie: {
            donut: {
                size: '64%',
                labels: {
                    show: true,
                    total: {
                        show: true,
                        label: 'Total',
                        formatter: function (w) {
                            return w.globals.seriesTotals.reduce((a, b) => a + b, 0).toLocaleString('es-MX');
                        }
                    }
                }
            }
        }
    }
}).render();

new ApexCharts(document.getElementById('activeOrdersTrendChart'), {
    ...sharedChartConfig,
    chart: { ...sharedChartConfig.chart, type: 'area' },
    series: [{ name: 'Órdenes creadas', data: dailyValues }],
    colors: ['#16a34a'],
    stroke: { curve: 'smooth', width: 3 },
    fill: {
        type: 'gradient',
        gradient: {
            shadeIntensity: 1,
            opacityFrom: 0.32,
            opacityTo: 0.04,
            stops: [0, 90, 100]
        }
    },
    markers: { size: 4 },
    xaxis: { categories: dailyLabels, labels: { style: { colors: '#4d6283' } } },
    yaxis: {
        labels: {
            formatter: value => Math.round(value).toLocaleString('es-MX'),
            style: { colors: '#5f7392' }
        }
    }
}).render();
</script>
}
