@using System.Globalization
@model Trackii.Models.Gerencia.RealInventory.RealInventoryMapVm

@{
    ViewData["Title"] = "Inventario real";
    var spanish = new CultureInfo("es-MX");
    var grandTotal = Model.GrandTotalPieces;
}

@if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
{
    <div class="d-flex justify-content-end mb-3">
        <button id="btnSendTestEmail" class="btn btn-primary shadow-sm">
            <i class="fa-solid fa-file-excel me-2"></i> Enviar Excel de Discretos
        </button>
    </div>
}

<div class="dashboard real-inventory-dashboard">
    <div class="page-header real-inventory-header">
        <div>
            <h2>INVENTARIO REAL</h2>
            <p class="subtitle">Corte: <strong>@Model.DataCutoffUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm", spanish)</strong>.</p>
        </div>
        <div class="real-inventory-kpis">
            <span class="chip chip-muted">Localidades: @Model.Rows.Count</span>
            <span class="chip">Piezas totales: @grandTotal.ToString("N0")</span>
        </div>
    </div>

    <section class="card apple-card real-inventory-card">
        <div class="table-wrapper real-inventory-table-wrapper">
            <table class="table real-inventory-table" id="inventoryRealTable">
                <thead>
                    <tr>
                        <th>LOCALIDAD</th>
                        @foreach (var col in Model.Columns)
                        {
                            <th class="text-end">@col</th>
                        }
                        <th class="text-end total-column">TOTAL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr data-location="@row.LocationName" data-total="@row.TotalPieces">
                            <td class="location-cell">@row.LocationName</td>
                            @foreach (var col in Model.Columns)
                            {
                                var qty = row.PiecesByColumn.TryGetValue(col, out var value) ? value : 0;
                                <td data-family="@col" class="text-end @(qty == 0 ? "is-zero" : string.Empty)">
                                    @if (qty > 0)
                                    {
                                        <a asp-action="InventarioRealDetalle"
                                           asp-route-location="@row.LocationName"
                                           asp-route-familyGroup="@col"
                                           class="inventory-link">
                                            @qty.ToString("N0")
                                        </a>
                                    }
                                    else
                                    {
                                        <span>0</span>
                                    }
                                </td>
                            }
                            <td class="text-end total-column">@row.TotalPieces.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>TOTAL GENERAL</th>
                        @foreach (var col in Model.Columns)
                        {
                            var totalByColumn = Model.TotalsByColumn.TryGetValue(col, out var total) ? total : 0;
                            <th class="text-end">@totalByColumn.ToString("N0")</th>
                        }
                        <th class="text-end total-column">@grandTotal.ToString("N0")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>

    @if (ViewBag.DaysMap is Trackii.Models.Gerencia.RealInventory.RealInventoryDaysVm daysMap)
    {
        <partial name="_RealInventoryDaysMap" model="daysMap" />
    }
</div>

<style>
    .day-color-1 { background-color: rgba(255, 99, 132, 0.14); }
    .day-color-2 { background-color: rgba(255, 159, 64, 0.14); }
    .day-color-3 { background-color: rgba(255, 205, 86, 0.14); }
    .day-color-4 { background-color: rgba(75, 192, 192, 0.14); }
    .day-color-5 { background-color: rgba(54, 162, 235, 0.14); }
    .day-color-6 { background-color: rgba(153, 102, 255, 0.14); }
    .day-color-7 { background-color: rgba(201, 203, 207, 0.2); }
    .day-match {
        outline: 2px solid currentColor;
        font-weight: 600;
    }
    @@media (max-width: 1024px) {
        .real-inventory-table-wrapper {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .real-inventory-table {
            min-width: 980px;
        }
    }

    @@media (max-width: 768px) and (orientation: portrait) {
        .real-inventory-table {
            min-width: 1100px;
            font-size: 0.82rem;
        }
    }

    @@media (max-width: 932px) and (orientation: landscape) {
        .real-inventory-table {
            min-width: 980px;
            font-size: 0.82rem;
        }
    }
</style>

@section Scripts {
    <script>
        (() => {
            const table = document.getElementById('inventoryRealTable');
            if (!table) return;

            const btnEmail = document.getElementById('btnSendTestEmail');
            if (btnEmail) {
                btnEmail.addEventListener('click', async function () {
                    const originalText = this.innerHTML;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Generando y enviando...';
                    this.disabled = true;

                    try {
                        const response = await fetch('/Gerencia/SendInventoryExcel', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });

                        let data = null;
                        try {
                            data = await response.json();
                        } catch {
                            data = { message: response.statusText };
                        }

                        if (response.ok) {
                            alert('Éxito: ' + data.message);
                        } else {
                            alert('Error: ' + (data.message || response.statusText));
                        }
                    } catch (error) {
                        console.error(error);
                            alert('Error de conexión al intentar enviar el reporte.');
                    } finally {
                        this.innerHTML = originalText;
                        this.disabled = false;
                    }
                });
            }

            const dayLinks = Array.from(document.querySelectorAll('.days-cell-link'));
            const clearDayComparison = () => {
                table.querySelectorAll('.day-match, .day-color-1, .day-color-2, .day-color-3, .day-color-4, .day-color-5, .day-color-6, .day-color-7')
                    .forEach(el => {
                        el.classList.remove('day-match', 'day-color-1', 'day-color-2', 'day-color-3', 'day-color-4', 'day-color-5', 'day-color-6', 'day-color-7');
                    });
            };

            dayLinks.forEach(link => {
                link.addEventListener('click', () => {
                    const family = link.dataset.family;
                    const day = link.dataset.day || '';
                    const locations = (link.dataset.locations || '')
                        .split(',')
                        .map(x => x.trim().toLowerCase())
                        .filter(Boolean);
                    if (!family || locations.length === 0) return;

                    clearDayComparison();

                    const dayNumber = Number((day.match(/\d+/) || [0])[0]);
                    const dayClass = dayNumber >= 1 && dayNumber <= 7 ? `day-color-${dayNumber}` : '';

                    const rows = Array.from(table.querySelectorAll('tbody tr'));
                    let firstMatch = null;
                    rows.forEach(row => {
                        const rowLocation = (row.dataset.location || '').toLowerCase();
                        const matchesLocation = locations.includes(rowLocation);
                        if (!matchesLocation) return;

                        const cells = Array.from(row.querySelectorAll('td[data-family]'));
                        cells.forEach(cell => {
                            if ((cell.dataset.family || '').toLowerCase() === family.toLowerCase()) {
                                cell.classList.add('day-match');
                                if (dayClass) cell.classList.add(dayClass);
                                firstMatch ??= cell;
                            }
                        });
                    });

                    if (firstMatch) {
                        firstMatch.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else {
                        table.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });
        })();
    </script>
}
