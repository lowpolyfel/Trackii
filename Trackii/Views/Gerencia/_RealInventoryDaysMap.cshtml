@model Trackii.Models.Gerencia.RealInventory.RealInventoryDaysVm

<section class="card apple-card real-inventory-card mt-4">
    <div class="card-heading">
        <h3>Inventario por días operativos</h3>
    </div>

    @if (Model.ValidationWarnings.Any())
    {
        <div class="alert alert-warning mb-3" role="alert">
            <strong>Validación:</strong>
            <ul class="mb-0">
                @foreach (var warning in Model.ValidationWarnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }

    <div class="table-wrapper real-inventory-table-wrapper">
        <table class="table real-inventory-table">
            <thead>
                <tr>
                    <th>Día operativo</th>
                    @foreach (var family in Model.Rows.Select(x => x.FamilyGroup))
                    {
                        <th class="text-end">@family</th>
                    }
                    <th class="text-end total-column">Total</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.DayColumns.Count; i++)
                {
                    var day = Model.DayColumns[i];
                    var dayClass = $"day-color-{i + 1}";
                    var dayTotal = 0;

                    <tr>
                        <td class="location-cell @dayClass">@day</td>
                        @foreach (var familyRow in Model.Rows)
                        {
                            familyRow.PiecesByDay.TryGetValue(day, out var qty);
                            familyRow.LocationsByDay.TryGetValue(day, out var locations);
                            if (qty.HasValue)
                            {
                                dayTotal += qty.Value;
                            }

                            <td class="text-end @dayClass @(qty.HasValue && qty.Value == 0 ? "is-zero" : string.Empty)">
                                @if (!qty.HasValue || locations is null)
                                {
                                    <span>-</span>
                                }
                                else
                                {
                                    var locs = string.Join(",", locations);
                                    <button type="button"
                                            class="btn btn-link p-0 inventory-link days-cell-link"
                                            data-day="@day"
                                            data-family="@familyRow.FamilyGroup"
                                            data-locations="@locs">
                                        @qty.Value.ToString("N0")
                                    </button>
                                }
                            </td>
                        }
                        <td class="text-end total-column @dayClass">@dayTotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>TOTAL GENERAL</th>
                    @foreach (var family in Model.Rows.Select(x => x.FamilyGroup))
                    {
                        var totalByFamily = Model.Rows
                            .First(x => x.FamilyGroup.Equals(family, StringComparison.OrdinalIgnoreCase))
                            .TotalPieces;
                        <th class="text-end">@totalByFamily.ToString("N0")</th>
                    }
                    <th class="text-end total-column">@Model.GrandTotalPieces.ToString("N0")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</section>
