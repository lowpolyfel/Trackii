@using System.Text.Json
@using System.Globalization
@model Trackii.Models.Gerencia.GerenciaDashboardVm

@{
    ViewData["Title"] = "Gerencia";
    var spanish = new CultureInfo("es-MX");
    var weekRatioClass = Model.WeekRatioUp ? "ratio-up" : "ratio-down";
    var dayRatioClass = Model.DayRatioUp ? "ratio-up" : "ratio-down";
}

<div class="dashboard gerencia-dashboard-v2">
    <div class="page-header">
        <div>
            <h2>Lobby de órdenes · Discretos</h2>
            <p class="subtitle">Actualizado automáticamente al día y hora actual: <strong>@Model.SnapshotAtUtc.ToString("dddd dd MMM yyyy HH:mm", spanish)</strong>.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Gerencia" asp-action="DiscreteMap" class="btn btn-primary">
                <i class="fa-solid fa-map"></i>
                Mapa de discretos
            </a>
            <a asp-controller="Gerencia" asp-action="BackendLobby" class="btn btn-primary">
                <i class="fa-solid fa-table-cells-large"></i>
                Lobby gerencia
            </a>
            <a asp-controller="Gerencia" asp-action="ActiveOrders" class="btn btn-secondary">
                <i class="fa-solid fa-list-check"></i>
                Ver órdenes activas
            </a>
        </div>
    </div>

    <section class="executive-grid">
        <article class="card apple-card executive-card">
            <span class="kpi-label">Órdenes nuevas del día</span>
            <strong class="executive-value">@Model.NewOrdersToday.ToString("N0")</strong>
            <div class="executive-ratios">
                <span class="ratio-pill @weekRatioClass">
                    <i class="fa-solid @(Model.WeekRatioUp ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i>
                    Week ratio @Model.WeekRatioPercent.ToString("+#0.0;-#0.0;0.0")%
                </span>
                <span class="ratio-pill @dayRatioClass">
                    <i class="fa-solid @(Model.DayRatioUp ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i>
                    Day ratio @Model.DayRatioPercent.ToString("+#0.0;-#0.0;0.0")%
                </span>
            </div>
            <small>Comparativo contra el mismo día de la semana pasada (@Model.PreviousWeekSameDayNewOrders.ToString("N0") órdenes).</small>
        </article>

        <article class="card apple-card executive-card">
            <span class="kpi-label">Órdenes actualmente en piso</span>
            <strong class="executive-value">@Model.OnFloorTotal.ToString("N0")</strong>
            <div class="status-tags-grid">
                <span class="status-tag open">Abiertas: <strong>@Model.OpenOrdersCount</strong></span>
                <span class="status-tag finished">Terminadas: <strong>@Model.FinishedOrdersCount</strong></span>
                <span class="status-tag cancelled">Canceladas: <strong>@Model.CancelledOrdersCount</strong></span>
                <span class="status-tag hold">Hold: <strong>@Model.HoldOrdersCount</strong></span>
            </div>
            <small>Incluye OPEN, IN_PROGRESS, FINISHED, CANCELLED y HOLD.</small>
        </article>
    </section>

    <div class="chart-grid">
        <div class="card chart-card apple-card">
            <h3>Estado de órdenes en piso</h3>
            <div id="ordersPieChart" class="chart-host"></div>
        </div>
        <div class="card chart-card apple-card">
            <h3>Localidades con más atasco (+4 días sin escaneo)</h3>
            <div id="backlogByLocationChart" class="chart-host"></div>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="card kpi-highlight delay apple-card">
            <h3>Órdenes atrasadas (+7 días)</h3>
            @if (!Model.DelayedOrders.Any())
            {
                <p class="subtitle">Sin atrasos críticos actualmente.</p>
            }
            else
            {
                <ul class="new-orders-list delayed-orders-list">
                    @foreach (var order in Model.DelayedOrders)
                    {
                        <li class="new-order-item delayed-order-item">
                            <div class="new-order-header">
                                <strong>#@order.WoNumber</strong>
                                <span class="new-order-status delayed-status">@order.DaysDelayed días</span>
                            </div>
                            <p class="new-order-product">@order.Product</p>
                            <div class="new-order-meta">
                                <span><i class="fa-solid fa-location-dot"></i> @(string.IsNullOrWhiteSpace(order.CurrentLocation) ? "Sin localidad" : order.CurrentLocation)</span>
                                <span><i class="fa-solid fa-hourglass-half"></i> @UiTextHelper.NormalizeStatus(order.Status)</span>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card kpi-highlight incoming apple-card">
            <h3>Órdenes nuevas</h3>
            @if (!Model.NewOrders.Any())
            {
                <p class="subtitle">Sin nuevas órdenes registradas.</p>
            }
            else
            {
                <ul class="new-orders-list">
                    @foreach (var order in Model.NewOrders)
                    {
                        <li class="new-order-item">
                            <div class="new-order-header">
                                <strong>#@order.WoNumber</strong>
                                <span class="new-order-status">@UiTextHelper.NormalizeStatus(order.Status)</span>
                            </div>
                            <p class="new-order-product">@order.Product</p>
                            <div class="new-order-meta">
                                <span><i class="fa-solid fa-location-dot"></i> @(string.IsNullOrWhiteSpace(order.CurrentLocation) ? "Sin localidad" : order.CurrentLocation)</span>
                                <span><i class="fa-solid fa-clock"></i> @(order.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Sin fecha WIP")</span>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        const normalizeStatusLabel = (value) => {
            const map = {
                OPEN: 'Abiertas',
                IN_PROGRESS: 'En progreso',
                CANCELLED: 'Canceladas',
                FINISHED: 'Terminadas',
                ACTIVE: 'Activa',
                HOLD: 'Hold',
                SCRAPPED: 'Desechada',
                INACTIVE: 'Inactiva'
            };

            const key = (value || '').toString().toUpperCase();
            return map[key] || value;
        };

        const orderLabelsRaw = @Html.Raw(JsonSerializer.Serialize(Model.OrderStatusChart.Labels));
        const orderLabels = orderLabelsRaw.map(normalizeStatusLabel);
        const orderValues = @Html.Raw(JsonSerializer.Serialize(Model.OrderStatusChart.Values));
        const backlogLabels = @Html.Raw(JsonSerializer.Serialize(Model.BacklogByLocationChart.Labels));
        const backlogValues = @Html.Raw(JsonSerializer.Serialize(Model.BacklogByLocationChart.Values));

        const pieContainer = document.getElementById('ordersPieChart');
        const backlogContainer = document.getElementById('backlogByLocationChart');

        if (pieContainer) {
            pieContainer.innerHTML = '';
            new ApexCharts(pieContainer, {
                chart: { type: 'donut', height: 300, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
                labels: orderLabels,
                series: orderValues,
                stroke: { width: 2, colors: ['#ffffff'] },
                legend: { position: 'bottom' },
                colors: ['#1d9bf0', '#3559e0', '#20bf6b', '#ff6b6b', '#f4a261'],
                plotOptions: { pie: { donut: { size: '55%', labels: { show: true, total: { show: true, label: 'Total' } } } } }
            }).render();
        }

        if (backlogContainer) {
            backlogContainer.innerHTML = '';
            new ApexCharts(backlogContainer, {
                chart: { type: 'bar', height: 300, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
                series: [{ name: 'Órdenes con resago', data: backlogValues }],
                xaxis: { categories: backlogLabels, labels: { style: { fontSize: '12px' } } },
                plotOptions: { bar: { borderRadius: 8, columnWidth: '48%' } },
                colors: ['#ff6b6b'],
                dataLabels: { enabled: true },
                grid: { borderColor: 'rgba(80, 110, 150, 0.12)', strokeDashArray: 4 }
            }).render();
        }
    </script>
}
