@using System.Text.Json
@using System.Globalization
@model Trackii.Models.Gerencia.GerenciaDashboardVm

@{
    ViewData["Title"] = "Gerencia";
    var spanish = new CultureInfo("es-MX");
}

<div class="dashboard">
    <div class="page-header">
        <div>
            <h2>Gerencia - Discretos</h2>
            <p class="subtitle">Vista ejecutiva con foco en cronograma semanal, desempeño de órdenes y alertas críticas.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Gerencia" asp-action="DiscreteMap" class="btn btn-primary">
                <i class="fa-solid fa-map"></i>
                Ver mapa completo
            </a>
            <a asp-controller="Gerencia" asp-action="ActiveOrders" class="btn btn-secondary">
                <i class="fa-solid fa-list-check"></i>
                Órdenes activas (detalle)
            </a>
        </div>
    </div>

    <div class="card gerencia-weekly-card">
        <div class="page-header">
            <div>
                <h3>Cronograma semanal por subfamilia (solo piezas)</h3>
                <p class="subtitle">Haz click en un día para abrir el detalle de órdenes.</p>
            </div>
            <div class="header-actions">
                <a asp-controller="Gerencia" asp-action="DiscreteMap" class="btn btn-secondary">Ver más</a>
            </div>
        </div>
        <div class="table-wrapper">
            <table class="table gerencia-weekly-table">
                <thead>
                    <tr>
                        <th>Día</th>
                        @foreach (var subfamily in Model.WeeklyOutput.Subfamilies)
                        {
                            <th>@subfamily</th>
                        }
                        <th class="text-right">Total piezas</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.WeeklyOutput.Rows.Any())
                    {
                        <tr>
                            <td colspan="@(Model.WeeklyOutput.Subfamilies.Count + 2)" class="empty">Sin datos para la semana actual.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in Model.WeeklyOutput.Rows)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Gerencia" asp-action="DiscreteDay" asp-route-day="@row.Day.ToString("yyyy-MM-dd")" class="day-link">
                                        @row.Day.ToString("dddd dd MMM", spanish)
                                    </a>
                                </td>
                                @foreach (var cell in row.Cells)
                                {
                                    <td><span class="weekly-pill qty">@cell.Qty</span></td>
                                }
                                <td class="text-right">@row.TotalQty</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="chart-grid">
        <div class="card chart-card apple-card">
            <h3>Órdenes por estado (normalizado)</h3>
            <canvas id="ordersPieChart"></canvas>
        </div>
        <div class="card chart-card apple-card">
            <h3>Piezas por localidad</h3>
            <canvas id="productionChart"></canvas>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="card kpi-highlight delay apple-card">
            <h3>Órdenes atrasadas (+7 días)</h3>
            @if (!Model.DelayedOrders.Any())
            {
                <p class="subtitle">Sin atrasos críticos actualmente.</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var order in Model.DelayedOrders)
                    {
                        <li><strong>@order.WoNumber</strong> · @order.Product · @order.DaysDelayed días</li>
                    }
                </ul>
            }
            <a asp-controller="Gerencia" asp-action="WorkOrders" class="btn btn-secondary">Ver más</a>
        </div>

        <div class="card kpi-highlight incoming apple-card">
            <h3>Órdenes nuevas</h3>
            @if (!Model.NewOrders.Any())
            {
                <p class="subtitle">Sin nuevas órdenes registradas.</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var order in Model.NewOrders)
                    {
                        <li><strong>@order.WoNumber</strong> · @order.Product · @UiTextHelper.NormalizeStatus(order.Status)</li>
                    }
                </ul>
            }
            <a asp-controller="Gerencia" asp-action="ActiveOrders" class="btn btn-secondary">Ver más</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const normalizeStatusLabel = (value) => {
            const map = {
                OPEN: 'Activa',
                IN_PROGRESS: 'En progreso',
                CANCELLED: 'Cancelada',
                FINISHED: 'Finalizada',
                ACTIVE: 'Activa',
                HOLD: 'En espera',
                SCRAPPED: 'Desechada',
                INACTIVE: 'Inactiva'
            };

            const key = (value || '').toString().toUpperCase();
            return map[key] || value;
        };

        const orderLabelsRaw = @Html.Raw(JsonSerializer.Serialize(Model.OrderStatusChart.Labels));
        const orderLabels = orderLabelsRaw.map(normalizeStatusLabel);
        const orderValues = @Html.Raw(JsonSerializer.Serialize(Model.OrderStatusChart.Values));
        const productionLabels = @Html.Raw(JsonSerializer.Serialize(Model.ProductionByLocationChart.Labels));
        const productionValues = @Html.Raw(JsonSerializer.Serialize(Model.ProductionByLocationChart.Values));
        const commonLegend = {
            labels: {
                usePointStyle: true,
                pointStyle: 'circle',
                boxWidth: 10,
                color: '#30435f',
                font: { family: 'Inter, sans-serif', size: 12, weight: '600' }
            }
        };

        new Chart(document.getElementById('ordersPieChart'), {
            type: 'pie',
            data: {
                labels: orderLabels,
                datasets: [{
                    data: orderValues,
                    borderWidth: 2,
                    borderColor: '#ffffff',
                    hoverOffset: 12,
                    backgroundColor: ['#5ea3ff', '#8a8fff', '#36d6b6', '#ff7e8a', '#ffc66d']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: 12 },
                plugins: {
                    legend: { ...commonLegend, position: 'bottom' }
                }
            }
        });

        new Chart(document.getElementById('productionChart'), {
            type: 'bar',
            data: {
                labels: productionLabels,
                datasets: [{
                    label: 'Piezas producidas',
                    data: productionValues,
                    borderRadius: 12,
                    borderSkipped: false,
                    backgroundColor: ['#66b3ff', '#5d9dff', '#7cc3ff', '#93d4ff', '#7bb2ff']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        ticks: { color: '#536b8f', font: { weight: '600' } },
                        grid: { display: false }
                    },
                    y: {
                        ticks: { color: '#6a7f9f' },
                        grid: { color: 'rgba(80, 110, 150, 0.12)' }
                    }
                }
            }
        });
    </script>
}
